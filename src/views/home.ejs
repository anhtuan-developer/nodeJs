<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/styles.css" />
    <title>Home page</title>
  </head>
  <body>
    <div class="topnav">
      <a class="active" href="/">Home</a>
      <a href="/create">News</a>
      <a  href="/update">edit User</a>


    </div>
    <div class="table_container">
      <div class="title">list users</div>
      <table>
        <tr>
          <th>Id</th>
          <th>Email</th>
          <th>Name</th>
          <th>City</th>
          <th>Actions</th>
        </tr>
        
        
     <% listUsers.forEach(function(user , index) { %>
      <tr>
          <td><%= index + 1 %></td>
          <td><%= user.email %></td>
          <td><%= user.name %></td>
          <td><%= user.city %></td>
          <td>
            <button>Edit</button>
            <button>Delete</button>
          </td>
        </tr>
 <% }); %> 
      </table>
    </div>
  </body>
</html>
